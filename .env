# Frontend environment variables
# Copy this file to .env and fill in the values

# API URL - use full URL for production
# For development: Use your PC's local IP to allow mobile testing
# Find your IP with: ipconfig (look for IPv4 Address)
# For local development, comment out to use Vite proxy (recommended)
# VITE_API_URL=http://localhost:3000

# Note: Production API URL is set in Vercel environment variables (vercel.json)
# Do NOT set VITE_API_URL here for local development - it will bypass the Vite proxy
